import java.util.*;
import java.util.regex.*;

public class Main {

    // -------- Conversation State --------
    static String lastTopic = "";

    // -------- Exam Schedule --------
    static Map<String, String> examSchedule = new HashMap<>();

    static {
        examSchedule.put("1", "10 June");
        examSchedule.put("2", "12 June");
        examSchedule.put("3", "15 June");
        examSchedule.put("4", "18 June");
    }

    // -------- Extract Semester --------
    static String extractSemester(String text) {

        text = text.toLowerCase().trim();

        // sem 3 or semester 3
        Pattern p = Pattern.compile("(sem|semester)\\s*(\\d+)");
        Matcher m = p.matcher(text);

        if (m.find()) {
            return m.group(2);
        }

        // single number input
        if (text.matches("[1-4]")) {
            return text;
        }

        // year formats
        if (text.contains("first year") || text.contains("1st year")) return "1";
        if (text.contains("second year") || text.contains("2nd year")) return "2";
        if (text.contains("third year") || text.contains("3rd year")) return "3";
        if (text.contains("fourth year") || text.contains("4th year")) return "4";

        return null;
    }

    // -------- Chatbot Logic --------
    static String chatbot(String userInput) {

        userInput = userInput.toLowerCase();

        // First exam question
        if (userInput.contains("exam")) {

            lastTopic = "exam";

            String sem = extractSemester(userInput);

            if (sem != null) {
                return "Semester " + sem + " exams start on " + examSchedule.get(sem);
            }

            return "Which semester exam are you asking about?";
        }

        // Follow-up question
        if (lastTopic.equals("exam")) {

            String sem = extractSemester(userInput);

            if (sem != null) {
                lastTopic = "";
                return "Semester " + sem + " exams start on " + examSchedule.get(sem);
            }
        }

        // -------- FAQ --------
        if (userInput.contains("fee")) {
            return "B.Tech annual fee is Rs 1,50,000.";
        }

        if (userInput.contains("timing")) {
            return "College timings are 9 AM to 5 PM.";
        }

        if (userInput.contains("hostel")) {
            return "Hostel facility is available for students.";
        }

        if (userInput.contains("library")) {
            return "Library is open from 8 AM to 8 PM.";
        }

        if (userInput.contains("location")) {
            return "The college is located in Nagpur, Maharashtra.";
        }

        return "Sorry, I could not understand your question.";
    }

    // -------- Main Method --------
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("College Chatbot (Multi-turn Conversation)");
        System.out.println("Type 'exit' to stop\n");

        while (true) {

            System.out.print("You: ");
            String input = sc.nextLine();

            if (input.equalsIgnoreCase("exit")) {
                break;
            }

            String response = chatbot(input);
            System.out.println("Bot: " + response);
        }

        sc.close();
    }
}

