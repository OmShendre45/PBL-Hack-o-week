import java.util.Scanner;

public class CollegeChatbot {

    // -------- TEXT PREPROCESSING METHOD --------
    static String preprocess(String input) {

        // 1. Convert to lowercase
        input = input.toLowerCase();

        // 2. Remove punctuation and special characters
        input = input.replaceAll("[^a-z ]", "");

        // 3. Remove extra spaces
        input = input.replaceAll("\\s+", " ").trim();

        // 4. Basic normalization
        input = input.replace("fees", "fee");
        input = input.replace("timings", "timing");

        return input;
    }

    // -------- HELPER METHOD FOR SYNONYMS --------
    static boolean containsAny(String text, String[] words) {
        for (String w : words) {
            if (text.contains(w)) {
                return true;
            }
        }
        return false;
    }

    // -------- CHATBOT LOGIC --------
    static String chatbot(String userInput) {

        userInput = preprocess(userInput);

        // Synonym groups
        String[] feeWords = {"fee", "payment", "cost", "price"};
        String[] timeWords = {"time", "timing", "schedule", "hours"};
        String[] admissionWords = {"admission", "apply", "enroll", "registration"};
        String[] contactWords = {"contact", "phone", "number", "call"};
        String[] addressWords = {"address", "location", "where", "place"};
        String[] hostelWords = {"hostel", "room", "stay", "accommodation"};
        String[] libraryWords = {"library", "book", "study"};
        String[] examWords = {"exam", "test", "paper", "semester"};
        String[] attendanceWords = {"attendance", "present", "percentage"};
        String[] scholarshipWords = {"scholarship", "aid", "financial"};
        String[] exitWords = {"exit", "bye", "quit"};

        if (containsAny(userInput, feeWords)) {
            return "The annual fees for B.Tech is ₹1,50,000.";

        } else if (containsAny(userInput, timeWords)) {
            return "College timings are from 9:00 AM to 5:00 PM.";

        } else if (containsAny(userInput, admissionWords)) {
            return "Admissions are based on entrance exam and counseling process.";

        } else if (containsAny(userInput, contactWords)) {
            return "You can contact the college at +91-9876543210.";

        } else if (containsAny(userInput, addressWords)) {
            return "The college is located in Nagpur, Maharashtra.";

        } else if (containsAny(userInput, hostelWords)) {
            return "Hostel facilities are available for both boys and girls.";

        } else if (containsAny(userInput, libraryWords)) {
            return "The library is open from 8:00 AM to 8:00 PM.";

        } else if (containsAny(userInput, examWords)) {
            return "Semester exams are conducted at the end of each semester.";

        } else if (containsAny(userInput, attendanceWords)) {
            return "Minimum 75% attendance is mandatory.";

        } else if (containsAny(userInput, scholarshipWords)) {
            return "Scholarships are provided as per government norms.";

        } else if (containsAny(userInput, exitWords)) {
            return "Thank you! Have a great day.";

        } else {
            return "Sorry, I can answer only college-related questions.";
        }
    }

    // -------- MAIN METHOD --------
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("📘 Synonym-Aware College FAQ Chatbot");
        System.out.println("Type 'exit' or 'bye' to stop\n");

        while (true) {

            System.out.print("You: ");
            String userInput = sc.nextLine();

            String response = chatbot(userInput);
            System.out.println("Bot: " + response);

            if (userInput.toLowerCase().contains("exit") ||
                userInput.toLowerCase().contains("bye")) {
                break;
            }
        }

        sc.close();
    }
}

