import java.util.Scanner;

public class CollegeChatbot {

    // FAQ Questions
    static String[] questions = {
        "fee for btech",
        "college timing",
        "admission process",
        "contact number",
        "college location",
        "hostel facility",
        "library timing",
        "semester exam",
        "attendance requirement",
        "scholarship"
    };

    // FAQ Answers
    static String[] answers = {
        "The annual fees for B.Tech is ₹1,50,000.",
        "College timings are from 9:00 AM to 5:00 PM.",
        "Admissions are based on entrance exam and counseling.",
        "You can contact the college at +91-9876543210.",
        "The college is located in Nagpur, Maharashtra.",
        "Hostel facilities are available for both boys and girls.",
        "Library is open from 8:00 AM to 8:00 PM.",
        "Semester exams are conducted at the end of each semester.",
        "Minimum 75% attendance is required.",
        "Scholarships are provided according to government norms."
    };

    // Preprocess text
    static String preprocess(String text) {
        text = text.toLowerCase();
        text = text.replaceAll("[^a-z ]", "");
        return text;
    }

    // Calculate similarity
    static int similarity(String input, String question) {

        int score = 0;

        String[] inputWords = input.split(" ");
        String[] questionWords = question.split(" ");

        for (String w1 : inputWords) {
            for (String w2 : questionWords) {

                if (w1.equals(w2)) {
                    score++;
                }

            }
        }

        return score;
    }

    // Chatbot logic
    static String chatbot(String userInput) {

        userInput = preprocess(userInput);

        int bestScore = 0;
        int bestIndex = -1;

        for (int i = 0; i < questions.length; i++) {

            int score = similarity(userInput, questions[i]);

            if (score > bestScore) {
                bestScore = score;
                bestIndex = i;
            }

        }

        if (bestIndex != -1) {
            return answers[bestIndex];
        }

        return "Sorry, I don't understand the question.";
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("College FAQ Chatbot");
        System.out.println("Type 'exit' to stop");

        while (true) {

            System.out.print("You: ");
            String userInput = sc.nextLine();

            if (userInput.equalsIgnoreCase("exit")) {
                break;
            }

            String response = chatbot(userInput);
            System.out.println("Bot: " + response);
        }

        sc.close();
    }
}
